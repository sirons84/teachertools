generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Document {
  id          String @id @default(cuid())
  title       String
  serviceType String @default("sotongmun")

  originalFileUrl  String
  originalFileName String

  originalContent String @db.Text
  originalHtml    String @db.Text

  explanationContent String? @db.Text

  translations Translation[]
  embeddings   Embedding[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceType])
}

model Translation {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  langCode String
  content  String @db.Text
  html     String @db.Text

  createdAt DateTime @default(now())

  @@unique([documentId, langCode])
  @@index([documentId, langCode])
}

model Embedding {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  content String                    @db.Text
  vector  Unsupported("vector(1536)")

  @@index([documentId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  role     String
  content  String @db.Text
  langCode String

  createdAt DateTime @default(now())

  @@index([documentId])
}

model DebateSession {
  id        String       @id @default(cuid())
  teacherId String       @default("default")
  topic     String
  grade     String?
  subject   String?
  stage     SessionStage @default(A1_READY)
  state     Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  turns     DebateTurn[]
}

model DebateTurn {
  id        String        @id @default(cuid())
  sessionId String
  threadId  String?
  order     Int
  speaker   String
  side      String
  phase     String
  text      String        @db.Text
  createdAt DateTime      @default(now())
  session   DebateSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, threadId])
}

model ClassmateConversation {
  id        String             @id @default(cuid())
  browserId String
  agentId   String
  title     String
  messages  ClassmateMessage[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([browserId, updatedAt])
  @@index([userId, updatedAt])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  conversations ClassmateConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClassmateMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   ClassmateConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String
  content String @db.Text

  createdAt DateTime @default(now())

  @@index([conversationId])
}

enum SessionStage {
  A1_READY
  A1_DONE_WAIT_APPROVAL
  A2_READY
  A2_DONE
  A3_READY
  A3_RUNNING
  A3_DONE
  A4_READY
  A4_DONE
  A5_READY
  A5_DONE_WAIT_APPROVAL
  A6_READY
  A6_DONE
  COMPLETED
}

// ─────────────────────────────────────────────────────────
// 포스트잇 협업 보드 (Padlet-style)
// ─────────────────────────────────────────────────────────

model PadletBoard {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?       @db.Text
  bgColor     String        @default("#FAFAFA")
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  posts       PadletPost[]

  @@index([isArchived, createdAt])
}

model PadletPost {
  id          String              @id @default(cuid())
  boardId     String
  board       PadletBoard         @relation(fields: [boardId], references: [id], onDelete: Cascade)

  nickname    String
  sessionId   String
  contentText String?             @db.Text
  posX        Int                 @default(0)
  posY        Int                 @default(0)
  width       Int                 @default(240)
  height      Int                 @default(200)
  color       String              @default("#FFF59D")
  zIndex      Int                 @default(0)

  attachments PadletAttachment[]
  reactions   PadletReaction[]
  comments    PadletComment[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([boardId, createdAt(sort: Desc)])
  @@index([sessionId])
}

model PadletAttachment {
  id        String     @id @default(cuid())
  postId    String
  post      PadletPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  type      String     // 'image' | 'file' | 'embed'
  url       String
  filename  String?
  fileSize  Int?
  mimeType  String?
  embedMeta Json?

  createdAt DateTime   @default(now())

  @@index([postId])
}

model PadletReaction {
  id        String     @id @default(cuid())
  postId    String
  post      PadletPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  sessionId String
  emoji     String

  createdAt DateTime   @default(now())

  @@unique([postId, sessionId, emoji])
  @@index([postId])
}

model PadletComment {
  id        String     @id @default(cuid())
  postId    String
  post      PadletPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  nickname  String
  sessionId String
  content   String     @db.Text

  createdAt DateTime   @default(now())

  @@index([postId, createdAt])
}

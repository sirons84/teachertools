generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Document {
  id          String @id @default(cuid())
  title       String
  serviceType String @default("sotongmun")

  originalFileUrl  String
  originalFileName String

  originalContent String @db.Text
  originalHtml    String @db.Text

  explanationContent String? @db.Text

  translations Translation[]
  embeddings   Embedding[]
  chatMessages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceType])
}

model Translation {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  langCode String
  content  String @db.Text
  html     String @db.Text

  createdAt DateTime @default(now())

  @@unique([documentId, langCode])
  @@index([documentId, langCode])
}

model Embedding {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  content String                    @db.Text
  vector  Unsupported("vector(1536)")

  @@index([documentId])
}

model ChatMessage {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  role     String
  content  String @db.Text
  langCode String

  createdAt DateTime @default(now())

  @@index([documentId])
}

model DebateSession {
  id        String       @id @default(cuid())
  teacherId String       @default("default")
  topic     String
  grade     String?
  subject   String?
  stage     SessionStage @default(A1_READY)
  state     Json
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  turns     DebateTurn[]
}

model DebateTurn {
  id        String        @id @default(cuid())
  sessionId String
  threadId  String?
  order     Int
  speaker   String
  side      String
  phase     String
  text      String        @db.Text
  createdAt DateTime      @default(now())
  session   DebateSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId, threadId])
}

model ClassmateConversation {
  id        String             @id @default(cuid())
  browserId String
  agentId   String
  title     String
  messages  ClassmateMessage[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([browserId, updatedAt])
  @@index([userId, updatedAt])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  conversations ClassmateConversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClassmateMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   ClassmateConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String
  content String @db.Text

  createdAt DateTime @default(now())

  @@index([conversationId])
}

enum SessionStage {
  A1_READY
  A1_DONE_WAIT_APPROVAL
  A2_READY
  A2_DONE
  A3_READY
  A3_RUNNING
  A3_DONE
  A4_READY
  A4_DONE
  A5_READY
  A5_DONE_WAIT_APPROVAL
  A6_READY
  A6_DONE
  COMPLETED
}
